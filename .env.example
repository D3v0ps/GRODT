# ============================================================
# GRODT – miljövariabler
# Kopiera till .env.local för lokal utveckling. Committa aldrig
# riktiga nycklar.
# ============================================================

# --- Supabase (Projekt → Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=https://DITT-PROJEKT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Service role: ENDAST server-side (synk, audit log, kontohantering).
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Datakälla för API-synk ---
# bolagsverket = Värdefulla datamängder: berikar BEFINTLIGA bolag med
#                myndighetsdata + bokslut ur digitala årsredovisningar
#                (gratis; stödjer inte sökning – nya bolag via CSV/tic)
# tic          = tic.io (kräver TIC_API_KEY; stödjer SNI-prospektering)
# mock         = deterministisk testdata, endast utveckling/test
# (tomt)       = ingen API-synk; bolag importeras via CSV i Import & synk
DATA_PROVIDER=
TIC_API_KEY=
# Valfri override av bas-URL för tic.io:s LENS-API.
# TIC_API_BASE_URL=https://lens-api.tic.io

# --- Bolagsverket (Värdefulla datamängder) ---
# Anslutningsuppgifterna kommer i en krypterad zip från Bolagsverket
# (client id på rad 1, client secret på rad 2). Klistra ALDRIG in
# hemligheten i chattar eller kod – endast här/Vercel.
BOLAGSVERKET_CLIENT_ID=
BOLAGSVERKET_CLIENT_SECRET=
# Valfria overrides (default: produktionsmiljön).
# BOLAGSVERKET_BASE_URL=https://gw.api.bolagsverket.se/vardefulla-datamangder/v1
# BOLAGSVERKET_TOKEN_URL=https://portal.api.bolagsverket.se/oauth2/token
# BOLAGSVERKET_SCOPE=vardefulla-datamangder:read vardefulla-datamangder:ping
# Max antal bolag som berikas per synkkörning (default 40 – avvägt mot
# API-kvoten ~100 anrop/min och funktionens tidsgräns).
# BOLAGSVERKET_SYNC_LIMIT=40

# --- Google Places (kontaktberikning: telefon/hemsida) ---
# Skapa nyckel i Google Cloud Console med "Places API (New)" aktiverat.
# Hämtade nummer källmärks alltid "via Google – kan vara växelnummer".
# Kan även läggas i hemlighetsvalvet som 'google_places_api_key'.
GOOGLE_PLACES_API_KEY=

# --- Vercel Cron ---
# Slumpa fram en lång hemlighet, t.ex. `openssl rand -hex 32`.
CRON_SECRET=

# --- App ---
APP_BASE_URL=http://localhost:3000

# --- Seed (används endast av `npm run seed`) ---
SEED_ADMIN_EMAIL=admin@example.se
SEED_ADMIN_PASSWORD=byt-mig-direkt
SEED_ADMIN_NAME=Anna Lindqvist
